{
  "expo": {
    "name": "my-app",
    "slug": "my-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.play21947.my-app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "แอปพลิเคชันต้องการเข้าถึงคลังภาพเพื่อเปลี่ยนรูปโปรไฟล์ของคุณ",
        "NSCameraUsageDescription": "แอปพลิเคชันต้องการเข้าถึงกล้องเพื่อถ่ายรูปโปรไฟล์ของคุณ",
        "NSLocationWhenInUseUsageDescription": "แอปพลิเคชันต้องการเข้าถึงตำแหน่งของคุณเพื่อช่วยระบุที่อยู่จัดส่ง"
      },
      "config": {
        "googleMapsApiKey": "AIzaSyCVV4Ls8LCs1xC0MvKam7Xsf2kuPL28gNw"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCAKERDq7wFdL1msHmBnlfw-7NHRDfqGRM"
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "predictiveBackGestureEnabled": false,
      "package": "com.play21947.myapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-maps",
        {
          "iosGoogleMapsApiKey": "AIzaSyCVV4Ls8LCs1xC0MvKam7Xsf2kuPL28gNw"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "แอปต้องการเข้าถึงคลังภาพเพื่อเปลี่ยนรูปโปรไฟล์ของคุณ",
          "cameraPermission": "แอปต้องการเข้าถึงกล้องเพื่อถ่ายรูปโปรไฟล์ของคุณ"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "แอปต้องการเข้าถึงตำแหน่งของคุณเพื่อช่วยระบุที่อยู่จัดส่ง"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}